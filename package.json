{
  "name": "mobile-task-manager-automation",
  "version": "0.1.0",
  "private": true,
  "description": "React Native task manager with cross-platform and native mobile test automation",
  "scripts": {
    "prepare": "husky",
    "setup": "npm install && npm install --prefix app && npm run app:pods",
    "setup:android": "npm install && npm install --prefix app",
    "setup:ios": "npm run setup",
    "lint": "npm run lint --prefix app",
    "lint:fix": "npm run lint --prefix app -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --prefix app",
    "app:start": "npm run start --prefix app",
    "app:pods": "cd app/ios && bundle install && bundle exec pod install",
    "app:ios": "npm run ios --prefix app",
    "app:ios:setup": "npm run setup:ios && npm run app:ios",
    "app:android": "npm run android --prefix app",
    "app:android:setup": "npm run setup:android && npm run app:android",
    "app:test": "npm run test --prefix app"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
